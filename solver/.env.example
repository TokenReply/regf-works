# 邮箱服务配置（留空使用外部邮箱服务）
WORKER_DOMAIN=
EMAIL_DOMAIN=
ADMIN_PASSWORD=

# Turnstile 策略
REGISTER_TURNSTILE_ONLY=true

# YesCaptcha API Key（可选）
YESCAPTCHA_KEY=

# 协议支付配置（OpenRouter 不需要，可忽略）
PROTOCOL_PAYMENT_CARDS=""
PROTOCOL_CARD_BIND_LIMIT=0
PROTOCOL_YESCAPTCHA_ENABLED=false
PROTOCOL_MANUAL_CAPTCHA_MAX_WINDOWS=1
PROTOCOL_PAYMENT_HEADLESS=true
PROTOCOL_PAYMENT_TIMEOUT_SECONDS=120
